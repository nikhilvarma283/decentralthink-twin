# ─── Server ───────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ─── DecentralThink Core (Layer 1) ────────────────────────
# The twin calls Core for: vault, audit, auth, x402, policy
CORE_API_URL=https://core.decentralthink.com
CORE_API_KEY=                        # internal service key (set in Core's .env)

# ─── Qdrant (vector DB for RAG) ───────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=                      # set if using Qdrant Cloud

# ─── Embedding model ──────────────────────────────────────
# Points to the same Ollama instance used by Core
OLLAMA_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=nomic-embed-text     # or mxbai-embed-large

# ─── Inference model ──────────────────────────────────────
# Used for style-guided response generation
INFERENCE_MODEL=nous-hermes2

# ─── Knowledge boundary thresholds ────────────────────────
BOUNDARY_STRONG=0.85
BOUNDARY_PARTIAL=0.70
BOUNDARY_WEAK=0.40

# ─── Session ──────────────────────────────────────────────
SESSION_SECRET=change_me_64_char_random_string

# ─── Soul Token (Algorand) ────────────────────────────────
# Inherits from Core — Soul Token metadata stored on Algorand
ALGORAND_MNEMONIC=                   # funded testnet account for Soul Token minting
